{
  "name": "@alekstar79/qr-code",
  "description": "A simple QR code generator library",
  "author": "Aleksey Tarasenko <alekstar79@yandex.ru>",
  "version": "2.0.1",
  "type": "module",
  "license": "MIT",
  "private": false,
  "main": "./lib/index.js",
  "module": "./lib/index.js",
  "types": "./lib/types.d.ts",
  "exports": {
    ".": {
      "import": "./lib/index.js",
      "types": "./lib/types.d.ts"
    }
  },
  "keywords": [
    "typescript",
    "qr-code",
    "generator"
  ],
  "homepage": "https://alekstar79.github.io/qr-code",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/alekstar79/qr-code.git"
  },
  "bugs": {
    "url": "https://github.com/alekstar79/qr-code/issues"
  },
  "files": [
    "lib",
    "package.json",
    "README.md",
    "LICENSE"
  ],
  "publishConfig": {
    "access": "public",
    "registry": "https://registry.npmjs.org"
  },
  "scripts": {
    "dev": "vite --config vite.config.ts",
    "build:lib": "vite build --config vite.config.lib.ts && tsc --declaration --emitDeclarationOnly --outDir lib",
    "build": "vite build",
    "preview": "vite preview",
    "test": "vitest run",
    "test:coverage": "vitest run --coverage",
    "prepublishOnly": "npm run build:lib"
  },
  "devDependencies": {
    "@types/jsdom": "^21.1.7",
    "@types/node": "^20.12.12",
    "@vitest/coverage-v8": "^2.0.4",
    "canvas": "^2.11.2",
    "jsdom": "^24.1.3",
    "typescript": "^5.4.5",
    "vite": "^5.2.11",
    "vite-plugin-dts": "^4.5.4",
    "vitest": "^2.1.9"
  },
  "engines": {
    "node": ">=18"
  }
}
